{
  "name": "html-to-pptx",
  "version": "0.1.0",
  "description": "Convert all HTML files in a directory into a complete PowerPoint presentation.",
  "type": "module",
  "main": "src/scripts/convert.js",
  "bin": {
    "html-to-pptx": "src/scripts/convert.js"
  },
  "scripts": {
    "start": "node src/scripts/convert.js",
    "test": "node --test",
    "sync:dom-to-pptx": "node src/scripts/sync-dom-to-pptx.js",
    "sync:dom-to-pptx:check": "node src/scripts/sync-dom-to-pptx.js --check"
  },
  "keywords": [
    "html",
    "pptx",
    "powerpoint",
    "converter"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.0",
    "@fortawesome/free-brands-svg-icons": "^6.5.0",
    "@fortawesome/free-regular-svg-icons": "^6.5.0",
    "@fortawesome/free-solid-svg-icons": "^6.5.0",
    "@xmldom/xmldom": "^0.8.13",
    "esbuild": "^0.20.0",
    "express": "^5.2.1",
    "fonteditor-core": "^2.6.3",
    "get-port": "^7.2.0",
    "html2canvas": "^1.4.1",
    "htmlparser2": "^12.0.0",
    "jszip": "^3.10.1",
    "opentype.js": "^1.3.4",
    "pako": "^2.1.0",
    "playwright": "1.57.0",
    "pptxgenjs": "^3.12.0"
  }
}
